# Anthropic Claude API
CLAUDE_API_KEY=your_claude_api_key_here

# AWS Configuration
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=us-east-1
S3_BUCKET_NAME=your-bucket-name

# n8n Configuration
N8N_PORT=5678
N8N_URL=http://localhost:5678
N8N_API_KEY=your_n8n_api_key

# Blender Configuration
BLENDER_PATH=/usr/bin/blender
BLENDER_TEMP_DIR=/tmp/blender_rendering

# EC2 Configuration
# ============================================================================
EC2_INSTANCE_ID=i-xxxxxxxxxx
EC2_INSTANCE_TYPE=g5.2xlarge
EC2_SECURITY_GROUP=sg-xxxxxxxxxx
EC2_KEY_PAIR=your-key-pair-name
EC2_REGION=us-east-1
EC2_SUBNET_ID=subnet-xxxxxxxxxx
EC2_AVAILABILITY_ZONE=us-east-1a

# EC2 SSH Configuration (for remote execution)
EC2_SSH_KEY_PATH=~/.ssh/ec2-key-pair.pem
EC2_SSH_USER=ec2-user
EC2_SSH_PORT=22

# Application Configuration
# ============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=logs/application.log
DEBUG_MODE=false

# Job Configuration
# ============================================================================
JOB_TIMEOUT_SECONDS=14400  # 4 hours
JOB_MAX_RETRIES=3
JOB_RETRY_DELAY_SECONDS=30

# Workflow Timeouts (in seconds)
PHASE_2_TIMEOUT=60
PHASE_3_TIMEOUT=120
PHASE_4_TIMEOUT=60
PHASE_5_TIMEOUT=60
PHASE_6_TIMEOUT=7200
PHASE_7_TIMEOUT=300
PHASE_8_TIMEOUT=120

# Simulation Configuration
# ============================================================================
SIMULATION_FPS=30
SIMULATION_DURATION_SECONDS=30
SIMULATION_FRAME_RANGE_START=1
SIMULATION_FRAME_RANGE_END=900

# PDF Processing Configuration
# ============================================================================
PDF_MAX_FILE_SIZE_MB=100
PDF_EXTRACTION_METHOD=pdfplumber
PDF_LANGUAGE=en

# CAD Model Configuration
# ============================================================================
SUPPORTED_CAD_FORMATS=fbx,step,glb,obj
CAD_MAX_FILE_SIZE_MB=500
CAD_MESH_SIMPLIFICATION_TARGET=0.8  # 80% of original

# Rendering Configuration
# ============================================================================
RENDER_QUALITY=high  # low, medium, high
RENDER_DENOISING=true
RENDER_MOTION_BLUR=true
RENDER_DEPTH_OF_FIELD=false

# API Rate Limiting
# ============================================================================
OPENAI_RATE_LIMIT_RPM=3  # Requests per minute
OPENAI_RATE_LIMIT_TPM=90000  # Tokens per minute

# Storage Configuration
# ============================================================================
STORAGE_CLEANUP_ENABLED=true
STORAGE_CLEANUP_DAYS=30  # Delete temp files older than 30 days
STORAGE_COMPRESSION_ENABLED=true

# Notification Configuration (optional)
# ============================================================================
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
EMAIL_NOTIFICATION_ENABLED=false
EMAIL_FROM_ADDRESS=noreply@example.com
EMAIL_SMTP_SERVER=smtp.example.com
EMAIL_SMTP_PORT=587

# Development Configuration (optional)
# ============================================================================
MOCK_OPENAI_RESPONSES=false
MOCK_BLENDER_EXECUTION=false
ENABLE_PROFILING=false
PROFILE_OUTPUT_FILE=profile_results.txt

# Feature Flags
# ============================================================================
ENABLE_BATCH_PROCESSING=false
ENABLE_PROGRESSIVE_RENDERING=false
ENABLE_CACHE_OPTIMIZATION=false
ENABLE_ADVANCED_COLLISION_DETECTION=true
