{
  "name": "CAD Simulation Pipeline (Local)",
  "nodes": [
    {
      "parameters": {
        "jsCode": "const raw = $('List Input Files').first().json.stdout || '';\n\nconst supportedExts = ['.fbx','.usd','.usda','.usdc','.abc','.blend','.obj','.gltf','.glb'];\nconst parts = raw.split('---PDF---');\nconst cadLines = parts[0].split('\\n').map(f => f.trim()).filter(f => f.length > 0);\nconst pdfLines = (parts[1] || '').split('\\n').map(f => f.trim()).filter(f => f.length > 0);\n\nfunction getExt(f) { return f.slice(f.lastIndexOf('.')).toLowerCase(); }\nfunction getBase(f) { return f.slice(0, f.lastIndexOf('.')).toLowerCase(); }\n\nconst cadFiles = cadLines.filter(f => supportedExts.includes(getExt(f)));\nconst pdfFiles = pdfLines.filter(f => getExt(f) === '.pdf');\n\nlet match = null;\nfor (const cad of cadFiles) {\n  const cadBase = getBase(cad);\n  const pdf = pdfFiles.find(p => getBase(p) === cadBase);\n  if (pdf) {\n    match = { pairFound: true, baseName: cadBase, cadFile: cad, pdfFile: pdf };\n    break;\n  }\n}\n\nreturn [{ json: match ?? { pairFound: false, baseName: null, cadFile: null, pdfFile: null } }];"
      },
