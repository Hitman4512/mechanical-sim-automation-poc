    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const body = $input.item.json.body;\nconst record = body.Records[0];\n\nconst bucket = record.s3.bucket.name;\nconst key = decodeURIComponent(record.s3.object.key.replace(/\\+/g, ' '));\nconst eventTime = record.eventTime;\n\nconst fileExtension = key.split('.').pop().toLowerCase();\nconst fileType = fileExtension === 'pdf' ? 'pdf' : 'cad';\n\nconst jobId = `job-${Date.now()}`;\n\nreturn {\n  bucket,\n  key,\n  fileType,\n  fileExtension,\n  eventTime,\n  jobId\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        208,
        0
      ],
      "id": "1e605b75-d30d-4dc4-8374-718e786b0fb4",
      "name": "Parse S3 Payload"
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict",
            "version": 3
          },
          "conditions": [
            {
              "id": "dd58c23b-dcca-40a2-bae1-b71c28f0e024",
              "leftValue": "={{ $json.fileType }}",
              "rightValue": "pdf",
              "operator": {
                "type": "string",
                "operation": "equals",
                "name": "filter.operator.equals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
