      "parameters": {
        "jsCode": "const now = new Date();\nconst pad = n => String(n).padStart(2,'0');\nconst ts = `${now.getFullYear()}${pad(now.getMonth()+1)}${pad(now.getDate())}_${pad(now.getHours())}${pad(now.getMinutes())}${pad(now.getSeconds())}`;\n\nconst baseName = $input.first().json.baseName;\nconst jobId = `${baseName}_${ts}`;\n\nreturn [{\n  json: {\n    ...$input.first().json,\n    jobId,\n    intermediatesDir: `C:\\\\pipeline\\\\intermediates\\\\${jobId}`,\n    outputsDir: `C:\\\\pipeline\\\\outputs`,\n    logsDir: `C:\\\\pipeline\\\\logs`\n  }\n}];"
