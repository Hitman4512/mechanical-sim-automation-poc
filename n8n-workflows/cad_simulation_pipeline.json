        "jsCode": "const data = $input.item.json;\n\nreturn {\n  jobId: data.jobId,\n  cadBucket: data.bucket,\n  cadKey: data.key,\n  cadReceivedAt: data.eventTime,\n  status: 'cad_received'\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
