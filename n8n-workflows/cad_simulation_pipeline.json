    {
      "parameters": {
        "jsCode": "const pdfKey = $input.item.json.pdfKey;  \n// e.g., \"inputs/pdf/gearbox_v1.pdf\"\n\nconst baseName = pdfKey.split('/').pop().split('.')[0];  \n// → \"gearbox_v1\"\n\nreturn {\n  baseName,\n  lookInFolder: \"inputs/cad\",\n  originalKey: pdfKey,\n  jobId: $input.item.json.jobId\n};"
      },
      "type": "n8n-nodes-base.code",
